% Vendored from CTAN inline-images (LGPL 3.0).
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{inline-images}[2018/08/15 version 1.0 vendored for AutoOffice]

\RequirePackage{graphicx}

\newcommand{\inlineimg}[2]{%
  \newwrite\tempfile%
  \immediate\openout\tempfile=#1.base64%
  \immediate\write\tempfile{#2}%
  \immediate\closeout\tempfile%
  \immediate\write18{base64 -d #1.base64 > #1}%
  \includegraphics{#1}%
}
