{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "autooffice/html",
  "title": "AutoOffice HTML Report Payload",
  "description": "HTML 报告生成的通用输入载荷。HTML 格式不强制主题系统，通过 Handlebars 模板渲染",
  "type": "object",
  "required": ["sections"],
  "properties": {
    "title": {
      "type": "string",
      "description": "报告标题"
    },
    "subtitle": {
      "type": "string",
      "description": "副标题"
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "description": "章节标题" },
          "heading": { "type": "string", "description": "章节标题（别名）" },
          "content": { "type": "string", "description": "章节内容" },
          "body": { "type": "string", "description": "章节内容（别名）" }
        },
        "anyOf": [
          { "required": ["title"] },
          { "required": ["heading"] }
        ]
      },
      "description": "章节列表"
    },
    "_template": {
      "type": "string",
      "description": "内联 Handlebars 模板（可选）"
    }
  }
}
