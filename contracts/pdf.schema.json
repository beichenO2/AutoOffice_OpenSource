{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "autooffice/pdf",
  "title": "AutoOffice PDF Report Payload",
  "description": "结构化 PDF 报告生成的输入载荷，包含主题、元数据和章节内容",
  "type": "object",
  "required": ["pdf"],
  "properties": {
    "pdf": {
      "type": "object",
      "required": ["theme", "locale", "title", "sections"],
      "properties": {
        "theme": {
          "type": "string",
          "enum": [
            "academic",
            "business",
            "minimal",
            "elegant",
            "technical-report",
            "news-digest",
            "study-notes",
            "study-review"
          ],
          "description": "PDF 视觉主题标识"
        },
        "locale": {
          "type": "string",
          "enum": ["zh-CN", "en-US"],
          "description": "语言区域"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120,
          "description": "报告标题"
        },
        "subtitle": {
          "type": "string",
          "description": "副标题"
        },
        "author": {
          "type": "string",
          "description": "作者"
        },
        "date": {
          "type": "string",
          "description": "日期"
        },
        "toc": {
          "type": "boolean",
          "description": "是否生成自动目录页"
        },
        "headerText": {
          "type": "string",
          "description": "页眉文字（默认使用 title）"
        },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/PdfSectionInput"
          },
          "description": "章节列表"
        }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "PdfSectionInput": {
      "type": "object",
      "required": ["heading", "body"],
      "properties": {
        "heading": {
          "type": "string",
          "maxLength": 100,
          "description": "章节标题"
        },
        "level": {
          "type": "integer",
          "enum": [1, 2, 3],
          "description": "标题层级（1-3）"
        },
        "body": {
          "type": "string",
          "maxLength": 50000,
          "description": "章节正文（支持 Markdown 子集）"
        },
        "chart": {
          "type": "object",
          "required": ["kind", "data", "encoding", "mime"],
          "properties": {
            "kind": { "type": "string", "enum": ["svg", "png"] },
            "data": { "type": "string" },
            "encoding": { "type": "string", "enum": ["utf-8", "base64"] },
            "mime": { "type": "string" }
          },
          "additionalProperties": false,
          "description": "嵌入图表"
        }
      },
      "additionalProperties": false
    }
  }
}
