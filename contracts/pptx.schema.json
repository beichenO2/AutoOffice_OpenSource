{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "autooffice/pptx",
  "title": "AutoOffice PPTX Deck Payload",
  "description": "结构化 PPT 演示文稿生成的输入载荷",
  "type": "object",
  "required": ["pptx"],
  "properties": {
    "pptx": {
      "type": "object",
      "required": ["theme", "locale", "title", "slides"],
      "properties": {
        "theme": {
          "type": "string",
          "enum": [
            "academic",
            "business",
            "minimal",
            "nord",
            "tech",
            "warm",
            "slate"
          ],
          "description": "PPT 视觉主题标识"
        },
        "locale": {
          "type": "string",
          "enum": ["zh-CN", "en-US"],
          "description": "语言区域"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "演示文稿总标题"
        },
        "subtitle": {
          "type": "string",
          "description": "副标题"
        },
        "slides": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/PptxSlideInput"
          },
          "description": "幻灯片列表"
        }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "PptxSlideInput": {
      "type": "object",
      "required": ["title", "bullets"],
      "properties": {
        "title": {
          "type": "string",
          "maxLength": 80,
          "description": "幻灯片标题"
        },
        "bullets": {
          "type": "array",
          "maxItems": 6,
          "items": {
            "type": "string",
            "maxLength": 200
          },
          "description": "要点列表（最多 6 条）"
        },
        "chart_png_base64": {
          "type": "string",
          "description": "PNG 图表的 base64 编码"
        },
        "chart_alt": {
          "type": "string",
          "description": "图表替代文本"
        }
      },
      "additionalProperties": false
    }
  }
}
