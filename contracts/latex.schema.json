{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "autooffice/latex",
  "title": "AutoOffice LaTeX Report Payload",
  "description": "结构化 LaTeX 文档生成的输入载荷",
  "type": "object",
  "required": ["latex"],
  "properties": {
    "latex": {
      "type": "object",
      "required": ["theme", "locale", "title", "sections"],
      "properties": {
        "theme": {
          "type": "string",
          "enum": ["article", "report", "beamer", "cvpr", "uestc-thesis"],
          "description": "LaTeX 文档类型/主题"
        },
        "locale": {
          "type": "string",
          "enum": ["zh-CN", "en-US"],
          "description": "语言区域"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "description": "文档标题"
        },
        "author": {
          "type": "string",
          "description": "作者"
        },
        "date": {
          "type": "string",
          "description": "日期"
        },
        "abstract": {
          "type": "string",
          "description": "摘要"
        },
        "toc": {
          "type": "boolean",
          "description": "是否生成目录"
        },
        "bibliography": {
          "type": "array",
          "items": { "type": "string" },
          "description": "参考文献列表"
        },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/LatexSectionInput"
          },
          "description": "章节列表"
        }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "LatexSectionInput": {
      "type": "object",
      "required": ["heading", "body"],
      "properties": {
        "heading": {
          "type": "string",
          "maxLength": 150,
          "description": "章节标题"
        },
        "level": {
          "type": "integer",
          "enum": [1, 2, 3],
          "description": "标题层级（1-3）"
        },
        "body": {
          "type": "string",
          "maxLength": 100000,
          "description": "章节正文"
        },
        "math": {
          "type": "string",
          "description": "LaTeX 公式（不含 $..$ 包裹）"
        },
        "chartPngBase64": {
          "type": "string",
          "description": "PNG 图表的 base64 编码"
        },
        "mermaidCode": {
          "type": "string",
          "description": "Mermaid 图源代码"
        }
      },
      "additionalProperties": false
    }
  }
}
