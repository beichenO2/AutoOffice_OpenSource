{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "autooffice/docx",
  "title": "AutoOffice DOCX Report Payload",
  "description": "结构化 Word 文档生成的输入载荷",
  "type": "object",
  "required": ["docx"],
  "properties": {
    "docx": {
      "type": "object",
      "required": ["theme", "locale", "title", "sections"],
      "properties": {
        "theme": {
          "type": "string",
          "enum": ["academic", "business", "minimal"],
          "description": "Word 文档视觉主题标识"
        },
        "locale": {
          "type": "string",
          "enum": ["zh-CN", "en-US"],
          "description": "语言区域"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120,
          "description": "报告标题"
        },
        "subtitle": {
          "type": "string",
          "description": "副标题"
        },
        "author": {
          "type": "string",
          "description": "作者"
        },
        "date": {
          "type": "string",
          "description": "日期"
        },
        "toc": {
          "type": "boolean",
          "description": "是否生成目录"
        },
        "headerText": {
          "type": "string",
          "description": "页眉文字"
        },
        "footerText": {
          "type": "string",
          "description": "页脚文字"
        },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/DocxSectionInput"
          },
          "description": "章节列表"
        }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "DocxSectionInput": {
      "type": "object",
      "required": ["heading", "body"],
      "properties": {
        "heading": {
          "type": "string",
          "maxLength": 100,
          "description": "章节标题"
        },
        "level": {
          "type": "integer",
          "enum": [1, 2, 3],
          "description": "标题层级（1-3）"
        },
        "body": {
          "type": "string",
          "maxLength": 80000,
          "description": "章节正文"
        },
        "table": {
          "type": "object",
          "required": ["headers", "rows"],
          "properties": {
            "headers": {
              "type": "array",
              "maxItems": 20,
              "items": { "type": "string" }
            },
            "rows": {
              "type": "array",
              "items": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "additionalProperties": false,
          "description": "表格数据"
        },
        "chartPngBase64": {
          "type": "string",
          "description": "PNG 图表的 base64 编码"
        }
      },
      "additionalProperties": false
    }
  }
}
